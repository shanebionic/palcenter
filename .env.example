PALCENTER_ADMIN_USERNAME=admin
PALCENTER_ADMIN_PASSWORD=replace-with-a-long-random-password
PALCENTER_SESSION_SECRET=replace-with-at-least-32-random-characters

# Enable this only when PalCenter is served through HTTPS.
PALCENTER_SESSION_COOKIE_SECURE=false

# Optional comma-separated browser origins allowed to call port 3001 directly.
PALCENTER_CORS_ORIGINS=

# Optional operational settings.
PALCENTER_SESSION_DURATION_SECONDS=43200
PALCENTER_HISTORY_INTERVAL_SECONDS=30
PALCENTER_LOG_LEVEL=info
PALCENTER_BACKUP_MAX_BYTES=536870912
